# App
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aivrasol?retryWrites=true&w=majority

# Admin auth (JWT via jose)
ADMIN_JWT_SECRET=change-me-to-a-long-random-secret-min-16-chars
ADMIN_JWT_EXPIRES_IN=7d
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_EMAIL=admin@aivrasol.com
ADMIN_SEED_PASSWORD=change-me-secure-password

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# LongCat AI
LONGCAT_API_KEY=
LONGCAT_BASE_URL=https://api.longcat.ai
LONGCAT_MODEL=longcat-default

# Contact notifications
CONTACT_RECEIVER_EMAIL=hello@aivrasol.com
